{
    email {$ADMIN_EMAIL}

    log {
        format console
    }

    order jwtauth before reverse_proxy
}

{$DOMAIN} {
    # NOTE(pencelheimer): sanitize headers
    request_header -X-User-Id
    request_header -X-User-Role

    encode zstd gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Strict-Transport-Security "max-age=31536000;"
    }

    handle /docs {
        root * /etc/caddy/static
        rewrite * /index.html
        file_server
    }

    # NOTE(pencelheimer): openapi docs
    handle /api/v1/ {
        uri strip_prefix /api/v1
        reverse_proxy core-api:3000
    }

    handle /api/v1/public/* {
        uri strip_prefix /api/v1
        reverse_proxy core-api:3000
    }

    handle /api/v1/upload {
        header Access-Control-Expose-Headers "X-File-Name"
        header X-File-Name "{http.request.uuid}"

        jwtauth {
            jwk_url {$CLERK_ENDPOINT}/.well-known/jwks.json
            issuer_whitelist {$CLERK_ENDPOINT}

            user_claims sub role
        }

        # TODO(pencelheimer): redirect to the resume parser
    }

    handle /api/v1/* {
        jwtauth {
            jwk_url {$CLERK_ENDPOINT}/.well-known/jwks.json
            issuer_whitelist {$CLERK_ENDPOINT}

            user_claims sub role
        }

        uri strip_prefix /api/v1
        reverse_proxy core-api:3000 {
            header_up X-User-Id {http.auth.user.sub}
            header_up X-User-Role {http.auth.user.role}
        }
    }
}
